{
  "name": "project_s",
  "version": "0.1.0",
  "description": "Lightweight scenario AI orchestration MVP",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "bridge": "tsx watch src/bridge.ts",
    "bridge:start": "tsx src/bridge.ts",
    "start": "node dist/server.js",
    "redeploy": "bash scripts/redeploy-server.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "storage:verify": "tsx src/scripts/verifyNotion.ts",
    "storage:bootstrap": "tsx src/scripts/bootstrapNotion.ts",
    "notion:verify": "tsx src/scripts/verifyNotion.ts",
    "notion:bootstrap": "tsx src/scripts/bootstrapNotion.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
